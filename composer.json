{
    "name": "lornequinn/hierarchical-scope",
    "description": "Hierarchical scoping for Laravel models - filter any model by a tree-structured scope.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "livewire/livewire": "^3.0"
    },
    "suggest": {
        "livewire/livewire": "Required for scope switcher and breadcrumb UI components (^3.0)"
    },
    "autoload": {
        "psr-4": {
            "LorneQuinn\\HierarchicalScope\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LorneQuinn\\HierarchicalScope\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LorneQuinn\\HierarchicalScope\\HierarchicalScopeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
